# Docker environment configuration for FAP

# PostgreSQL
POSTGRES_USER=fapuser
POSTGRES_PASSWORD=fappassword
POSTGRES_DB=fap_coordinator

# Database URL (coordin coordinator)
DATABASE_URL=postgresql://fapuser:fappassword@postgres:5432/fap_coordinator

# Participant paths
PARTICIPANT_DOCS_PATH=examples/local_docs/data
PARTICIPANT_KB_PATH=examples/local_kb/data
PARTICIPANT_LOGS_PATH=examples/local_logs/data

# API endpoints (internal docker network)
FAP_COORDINATOR_URL=http://coordinator:8000
